# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# Do NOT put secrets here (e.g. Supabase service role key).

# Which environment this build targets (optional, for your own logic)
VITE_APP_ENV=development

# Supabase (Backend + Database + Auth + Storage)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME

# Multi-tenant mode (used in some services)
VITE_MULTI_TENANT=false

# Optional / future: custom API base (currently not used by the app)
VITE_API_URL=/api

# Optional / legacy: direct Postgres config (NOT usable from the browser; only relevant if you add a backend)
VITE_DB_TYPE=supabase
VITE_PG_HOST=localhost
VITE_PG_PORT=5432
VITE_PG_DATABASE=quality_system
VITE_PG_USERNAME=postgres
VITE_PG_PASSWORD=
VITE_PG_SSL=false

